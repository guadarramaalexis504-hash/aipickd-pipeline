{
  "name": "aipickd-pipeline",
  "version": "1.0.0",
  "description": "AIPickd autonomous AI affiliate blog pipeline",
  "private": true,
  "scripts": {
    "pipeline": "node scripts/run-pipeline.js",
    "long": "node scripts/generate-long-article.js",
    "forever": "node scripts/generate-forever.js",
    "health": "node scripts/health-check.js",
    "monitor": "node scripts/monitor-site.js",
    "dashboard": "node scripts/generate-dashboard.js",
    "lint": "eslint \"scripts/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint --fix \"scripts/**/*.js\" \"tests/**/*.js\"",
    "format": "prettier --check \"scripts/lib/**/*.js\" \"tests/**/*.js\"",
    "format:fix": "prettier --write \"scripts/lib/**/*.js\" \"tests/**/*.js\"",
    "syntax-check": "find scripts -maxdepth 2 -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test tests/*.js",
    "validate": "npm run syntax-check && npm run lint && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "nodemailer": "^8.0.10",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.3.0"
  }
}
