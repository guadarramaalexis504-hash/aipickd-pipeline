# ============================================
# AIPickd — Configuración de entorno
# ============================================
# Copia este archivo a .env y llena los valores reales
# NUNCA subas .env a git / github / ningún lado público
# ============================================

# ---- Dominio y sitio ----
SITE_NAME="AIPickd"
SITE_URL="https://aipickd.com"
SITE_LANGUAGE="en-US"

# ---- WordPress ----
WP_URL="https://aipickd.com"
WP_API_URL="https://aipickd.com/wp-json/wp/v2"
WP_USERNAME=""
# Usa un "Application Password" (Users > Profile > Application Passwords)
# NO uses tu contraseña normal
WP_APP_PASSWORD=""

# ---- Supabase ----
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ---- IAs (Bridge) ----
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-7"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# ---- Keyword Research (opcional, mes 2+) ----
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# ---- Imágenes (opcional) ----
UNSPLASH_ACCESS_KEY=""
# O usar generación con DALL-E (usa OPENAI_API_KEY)

# ---- Analytics ----
GOOGLE_ANALYTICS_ID=""
GOOGLE_SEARCH_CONSOLE_SITE=""

# ---- n8n (si se llama con webhook externo) ----
N8N_WEBHOOK_URL=""
N8N_WEBHOOK_SECRET=""

# ---- Configuración del pipeline ----
ARTICLES_PER_DAY=2
DEFAULT_NICHE="ai-writing"
AUTO_PUBLISH=false # si false, queda en draft pa' tu review
MIN_WORD_COUNT=2000
MAX_WORD_COUNT=3500

# ---- Costos límite (por seguridad) ----
MAX_AI_COST_PER_ARTICLE_USD=2.00
MAX_AI_COST_PER_DAY_USD=10.00
